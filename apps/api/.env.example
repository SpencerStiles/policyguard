# --- Database ----------------------------------------------------------------
# PostgreSQL connection string (asyncpg driver).
# For local dev with SQLite, use: sqlite+aiosqlite:///./data/policyguard.db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/policyguard

# --- LLM Providers -----------------------------------------------------------
# At least one API key is required for policy analysis to work.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Embedding ---------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Auth / Security ---------------------------------------------------------
# Generate with: openssl rand -base64 32
JWT_SECRET=changeme-generate-a-real-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- CORS --------------------------------------------------------------------
# JSON array of origins allowed for CORS (Next.js frontend URLs).
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- File & Vector Storage ---------------------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
DOMAIN_DATA_DIR=./data/domain
