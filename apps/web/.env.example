# PolicyGuard — Web App Environment Variables
# Copy this file to .env.local for local development.
# In Vercel: Settings → Environment Variables → add each key.

# URL of the FastAPI backend.
# - Local dev: http://localhost:8000
# - Vercel production: your Render service URL, e.g. https://policyguard-api.onrender.com
#   Set this in the Vercel dashboard AFTER deploying the API to Render.
#   The Next.js rewrite in next.config.js proxies /api/* → this URL.
API_URL=http://localhost:8000
