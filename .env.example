# ============================================================
# PolicyGuard AI - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# ── Local development ────────────────────────────────────────
# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/policyguard.db
# DATABASE_URL=postgresql+asyncpg://policyguard:changeme@localhost:5432/policyguard

# LLM API Keys (at least one required for analysis)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Models
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Storage
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads

# JWT (optional - for future auth)
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256

# CORS origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── Docker Compose ───────────────────────────────────────────
# These are used by docker-compose.yml
POSTGRES_PASSWORD=changeme
